generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  username       String    @unique
  email          String    @unique
  password       String?
  phone          String?
  dob            String?
  gender         String?
  googleId       String?   @unique @map("google_id")
  acceptedTerms  Int       @default(0) @map("accepted_terms")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastLogin      DateTime? @map("last_login")
  role           String?
  placeId        Int?      @map("place_id")
  scans          Scan[]
  rewards        UserReward[]
  @@map("users")
}

model Place {
  id                Int       @id @default(autoincrement())
  name              String
  tipo              String
  lugar             String
  description       String?
  imageUrl          String?   @map("image_url")
  rating            Float     @default(0)
  address           String?
  phone             String?
  priceRange        String?   @map("price_range")
  amenities         String?
  hasReward         Boolean   @default(false) @map("has_reward")
  rewardName        String?   @map("reward_name")
  rewardDescription String?   @map("reward_description")
  rewardIcon        String?   @default("🎁") @map("reward_icon")
  rewardStock       Int?      @map("reward_stock")
  isActive          Boolean   @default(true) @map("is_active")
  ownerId           Int?      @map("owner_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  scans             Scan[]
  rewards           UserReward[]
  @@map("places")
}

model Scan {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  placeId   Int      @map("place_id")
  qrCode    String?  @map("qr_code")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  @@map("scans")
}

model UserReward {
  id                Int       @id @default(autoincrement())
  userId            Int       @map("user_id")
  placeId           Int       @map("place_id")
  rewardName        String    @map("reward_name")
  rewardDescription String?   @map("reward_description")
  rewardIcon        String?   @default("🎁") @map("reward_icon")
  isRedeemed        Boolean   @default(false) @map("is_redeemed")
  earnedAt          DateTime  @default(now()) @map("earned_at")
  redeemedAt        DateTime? @map("redeemed_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  place             Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  @@map("user_rewards")
}
